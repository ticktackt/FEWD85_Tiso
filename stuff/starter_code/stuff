    "stats": { "avgRent1bed": "$1,200–1,800/mo", "groceriesPerMonth": "~$300", "internetSpeed": "100 Mbps avg", "happinessIndex": "7.2/10" },
    "visa": { "difficulty": "Easy", "popularRoutes": ["Visa 1", "Visa 2"], "processingTime": "4–8 weeks", "notes": "Short note on visa situation" },
    "pros": ["Pro 1", "Pro 2", "Pro 3", "Pro 4"],
    "cons": ["Con 1", "Con 2", "Con 3"],
    "bestFor": ["Type 1", "Type 2", "Type 3"],
    "verdict": "2–3 sentence honest summary of who this city suits"
  },
  "cityB": {
    "name": "full city name with country",
    "flag": "country flag emoji",
    "tagline": "one punchy sentence for relocators",
    "scores": { "costOfLiving": 55, "qualityOfLife": 90, "visaEase": 80, "safety": 92, "healthcare": 95, "jobMarket": 68, "englishFriendly": 85, "weather": 58 },
    "stats": { "avgRent1bed": "$900–1,400/mo", "groceriesPerMonth": "~$250", "internetSpeed": "200 Mbps avg", "happinessIndex": "8.1/10" },
    "visa": { "difficulty": "Moderate", "popularRoutes": ["Visa 1", "Visa 2"], "processingTime": "2–6 weeks", "notes": "Short note on visa situation" },
    "pros": ["Pro 1", "Pro 2", "Pro 3", "Pro 4"],
    "cons": ["Con 1", "Con 2", "Con 3"],
    "bestFor": ["Type 1", "Type 2", "Type 3"],
    "verdict": "2–3 sentence honest summary of who this city suits"
  },
  "recommendation": {
    "winner": "exact city name or Tie",
    "reason": "2–3 sentences explaining the recommendation",
    "keyDifferences": ["Difference 1", "Difference 2", "Difference 3"]
  }
}

Use realistic research-backed data. Scores 0–100. costOfLiving: higher = more affordable. difficulty must be exactly: Easy, Moderate, or Hard.`;

  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1500,
        messages: [{ role: 'user', content: prompt }]
      })
    });

    timers.forEach(clearTimeout);
    steps.forEach(s => document.getElementById(s).classList.add('visible'));

    if (!res.ok) throw new Error('API ' + res.status);
    const data = await res.json();
    const raw = (data.content?.[0]?.text || '').replace(/^```json\s*/i,'').replace(/^```/,'').replace(/```$/,'').trim();
    const parsed = JSON.parse(raw);
    hide('loading-view');
    renderResult(parsed);
  } catch(err) {
    timers.forEach(clearTimeout);
    hide('loading-view');
    show('error-view');
    document.getElementById('error-msg').textContent = 'Could not generate comparison. Check your connection and try again.';
  }
}

function renderResult(d) {
  fillCard('a', d.cityA);
  fillCard('b', d.cityB);

  const winA = d.recommendation.winner && d.cityA.name.toLowerCase().includes(d.recommendation.winner.toLowerCase());
  const winB = d.recommendation.winner && d.cityB.name.toLowerCase().includes(d.recommendation.winner.toLowerCase());
  document.getElementById('badge-a').style.display = winA ? 'inline-flex' : 'none';
  document.getElementById('badge-b').style.display = winB ? 'inline-flex' : 'none';
  document.getElementById('card-a').className = 'city-card' + (winA ? ' winner-a' : '');
  document.getElementById('card-b').className = 'city-card' + (winB ? ' winner-b' : '');

  document.getElementById('banner-title').textContent = d.recommendation.winner === 'Tie' ? "It's a tie — both are strong choices" : d.recommendation.winner + ' edges ahead';
  document.getElementById('banner-reason').textContent = d.recommendation.reason;
  document.getElementById('diff-pills').innerHTML = (d.recommendation.keyDifferences || []).map(x => '<span class="diff-pill">› ' + x + '</span>').join('');

  document.getElementById('leg-a').textContent = d.cityA.name.split(',')[0];
  document.getElementById('leg-b').textContent = d.cityB.name.split(',')[0];

  let tA = 0, tB = 0;
  document.getElementById('score-rows').innerHTML = SCORE_KEYS.map(k => {
    const sA = d.cityA.scores[k] || 0, sB = d.cityB.scores[k] || 0;
    tA += sA; tB += sB;
    const aWins = sA >= sB;
    return `<div class="score-row"><div class="score-meta"><span class="score-lbl">${SCORE_LABELS[k]}</span><div class="score-vals"><span class="score-val-a">${sA}</span><span class="score-sep">vs</span><span class="score-val-b">${sB}</span></div></div><div class="bar-wrap"><div class="bar-half left"><div class="bar-fill ${aWins?'bar-a':'bar-a-dim'}" style="width:${sA}%"></div></div><div class="bar-half"><div class="bar-fill ${!aWins?'bar-b':'bar-b-dim'}" style="width:${sB}%"></div></div></div></div>`;
  }).join('');
  document.getElementById('total-a').textContent = tA;
  document.getElementById('total-b').textContent = tB;

  document.getElementById('header-action').innerHTML = '<button class="new-btn" onclick="reset()" style="font-size:12px;padding:6px 12px;">⇄ New</button>';
  show('result-view');
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function fillCard(s, city) {
  document.getElementById('flag-'+s).textContent = city.flag;
  document.getElementById('name-'+s).textContent = city.name;
  document.getElementById('tagline-'+s).textContent = city.tagline;
  document.getElementById('rent-'+s).textContent = city.stats.avgRent1bed;
  document.getElementById('grocery-'+s).textContent = city.stats.groceriesPerMonth;
  document.getElementById('internet-'+s).textContent = city.stats.internetSpeed;
  document.getElementById('happy-'+s).textContent = city.stats.happinessIndex;
  const vd = document.getElementById('vdiff-'+s);
  vd.textContent = city.visa.difficulty;
  vd.className = 'difficulty ' + ({Easy:'diff-easy',Moderate:'diff-mod',Hard:'diff-hard'}[city.visa.difficulty] || 'diff-mod');
  document.getElementById('vnote-'+s).textContent = city.visa.notes;
  document.getElementById('vroutes-'+s).innerHTML = (city.visa.popularRoutes||[]).map(r=>'<span class="visa-route">'+r+'</span>').join('');
  document.getElementById('proscons-'+s).innerHTML =
    (city.pros||[]).map(p=>'<div class="pc-item"><div class="pc-dot pro"></div><span>'+p+'</span></div>').join('') +
    (city.cons||[]).map(c=>'<div class="pc-item"><div class="pc-dot con"></div><span>'+c+'</span></div>').join('');
  document.getElementById('bestfor-'+s).innerHTML = (city.bestFor||[]).map(b=>'<span class="tag tag-'+s+'">'+b+'</span>').join('');
  document.getElementById('verdict-'+s).textContent = city.verdict;
}

function reset() {
  hide('result-view'); hide('error-view');
  show('search-view');
  document.getElementById('cityA').value = '';
  document.getElementById('cityB').value = '';
  document.getElementById('header-action').innerHTML = '';
  document.querySelectorAll('.loading-step').forEach(s => s.classList.remove('visible'));
  checkBtn();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}
</script>

</body>
