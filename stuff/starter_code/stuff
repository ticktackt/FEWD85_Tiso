.score-row { margin-bottom: 9px; padding-bottom: 9px; border-bottom: 1px solid #f3f4f6; }
.score-row:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
.score-meta { display: flex; align-items: center; justify-content: space-between; margin-bottom: 5px; }
.score-lbl { font-size: 10px; color: #9ca3af; font-weight: 500; }
.score-vals { display: flex; gap: 4px; align-items: center; font-size: 10px; }
.score-val-a { font-weight: 700; color: #4338ca; }
.score-val-b { font-weight: 700; color: #6d28d9; }
.score-sep { color: #d1d5db; }
.bar-wrap { display: flex; gap: 3px; height: 5px; }
.bar-half { flex: 1; background: #f3f4f6; border-radius: 99px; overflow: hidden; display: flex; }
.bar-half.left { justify-content: flex-end; }
.bar-fill { height: 100%; border-radius: 99px; transition: width 0.7s ease; }
.bar-a { background: #6366f1; }
.bar-b { background: #7c3aed; }
.bar-a-dim { background: #c7d2fe; }
.bar-b-dim { background: #ddd6fe; }
.totals { border-top: 1px solid #f3f4f6; margin-top: 12px; padding-top: 12px; display: flex; justify-content: space-between; align-items: center; }
.total-num { font-size: 22px; font-weight: 700; }
.total-a { color: #4338ca; }
.total-b { color: #6d28d9; }
.total-label { font-size: 10px; color: #9ca3af; text-align: center; line-height: 1.5; }
.total-sub { font-size: 10px; color: #d1d5db; }

.new-btn { font-size: 13px; padding: 10px 20px; border-radius: 10px; border: 1px solid #e5e7eb; background: #fff; color: #6b7280; cursor: pointer; font-weight: 500; transition: all 0.15s; }
.new-btn:hover { background: #f9fafb; border-color: #c7d2fe; color: #4338ca; }
.new-btn-row { text-align: center; margin-top: 20px; padding-bottom: 12px; }

.powered { text-align: center; font-size: 11px; color: #9ca3af; margin-top: 24px; padding-bottom: 24px; }
</style>

</head>
