function show(id) { document.getElementById(id).style.display = 'block'; }
function hide(id) { document.getElementById(id).style.display = 'none'; }

function checkBtn() {
  const a = document.getElementById('cityA').value.trim();
  const b = document.getElementById('cityB').value.trim();
  document.getElementById('compare-btn').className = 'compare-btn ' + (a && b ? 'active' : 'disabled');
}

function handleKey(e) { if (e.key === 'Enter') runCompare(); }

function fillSuggestion(a, b) {
  document.getElementById('cityA').value = a;
  document.getElementById('cityB').value = b;
  checkBtn();
}

async function runCompare() {
  const a = document.getElementById('cityA').value.trim();
  const b = document.getElementById('cityB').value.trim();
  if (!a || !b) return;

  hide('search-view'); hide('error-view'); hide('result-view');
  show('loading-view');
  document.getElementById('loading-title').textContent = 'Analysing ' + a + ' vs ' + b + '...';

  const steps = ['step1','step2','step3','step4'];
  const timers = [700,1500,2600,3800].map((d,i) => setTimeout(() => document.getElementById(steps[i]).classList.add('visible'), d));

  const prompt = `You are a relocation data expert. Compare these two cities for someone considering international relocation.

City A: ${a}
City B: ${b}

Return ONLY valid JSON with this exact structure — no markdown, no explanation, no code fences:

{
