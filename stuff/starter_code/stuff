<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Arrivly — Compare Cities</title>
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f5f3ff; min-height: 100vh; color: #111; }

.header { background: #fff; border-bottom: 1px solid #e5e7eb; padding: 14px 20px; display: flex; align-items: center; gap: 12px; position: sticky; top: 0; z-index: 10; }
.logo { font-size: 18px; font-weight: 700; color: #4f46e5; letter-spacing: -0.5px; }
.logo span { color: #7c3aed; }
.header-titles { flex: 1; }
.header-title { font-size: 15px; font-weight: 600; color: #111; }
.header-sub { font-size: 11px; color: #9ca3af; margin-top: 1px; }
.header-action { margin-left: auto; }

.content { padding: 20px 16px; max-width: 960px; margin: 0 auto; }

.search-card { background: #fff; border: 1px solid #e5e7eb; border-radius: 16px; padding: 28px 24px; text-align: center; }
.search-icon { width: 52px; height: 52px; background: #eef2ff; border-radius: 14px; display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; font-size: 24px; }
.search-card h2 { font-size: 20px; font-weight: 700; color: #111; margin-bottom: 8px; }
.search-card p { font-size: 13px; color: #6b7280; margin-bottom: 22px; line-height: 1.6; }
.input-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 12px; }
@media (max-width: 480px) { .input-row { grid-template-columns: 1fr; } }
.input-wrap { text-align: left; }
.input-label { font-size: 11px; font-weight: 600; color: #9ca3af; margin-bottom: 5px; display: block; text-transform: uppercase; letter-spacing: 0.05em; }
.city-input { width: 100%; padding: 11px 14px; border: 1.5px solid #e5e7eb; border-radius: 10px; font-size: 14px; background: #fff; color: #111; outline: none; transition: border-color 0.15s, box-shadow 0.15s; }
.city-input:focus { border-color: #6366f1; box-shadow: 0 0 0 3px rgba(99,102,241,0.12); }
.city-input.violet:focus { border-color: #7c3aed; box-shadow: 0 0 0 3px rgba(124,58,237,0.12); }
.compare-btn { width: 100%; padding: 12px; border-radius: 10px; font-size: 14px; font-weight: 600; cursor: pointer; border: none; transition: all 0.15s; }
.compare-btn.active { background: #4f46e5; color: #fff; }
.compare-btn.active:hover { background: #4338ca; }
.compare-btn.active:active { transform: scale(0.99); }
.compare-btn.disabled { background: #f3f4f6; color: #9ca3af; cursor: not-allowed; }
.suggestions-label { font-size: 11px; color: #9ca3af; margin: 16px 0 8px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }
.suggestions { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
@media (max-width: 400px) { .suggestions { grid-template-columns: 1fr; } }
.suggestion { font-size: 12px; color: #6b7280; background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 10px; padding: 9px 12px; cursor: pointer; text-align: left; transition: all 0.15s; }
.suggestion:hover { border-color: #c7d2fe; background: #eef2ff; color: #4338ca; }

.loading { text-align: center; padding: 52px 20px; }
.spinner { width: 40px; height: 40px; border: 3px solid #e0e7ff; border-top-color: #4f46e5; border-radius: 50%; animation: spin 0.7s linear infinite; margin: 0 auto 20px; }
@keyframes spin { to { transform: rotate(360deg); } }
.loading h3 { font-size: 17px; font-weight: 700; color: #111; margin-bottom: 6px; }
.loading p { font-size: 13px; color: #6b7280; margin-bottom: 20px; }
.loading-steps { display: flex; flex-direction: column; gap: 8px; max-width: 280px; margin: 0 auto; }
.loading-step { font-size: 12px; color: #d1d5db; transition: color 0.4s; text-align: left; }
.loading-step.visible { color: #6b7280; }

.error-box { background: #fef2f2; border: 1px solid #fecaca; border-radius: 16px; padding: 24px; text-align: center; }
.error-box p { font-size: 13px; color: #dc2626; margin-bottom: 14px; }

.banner { background: linear-gradient(135deg, #4f46e5, #7c3aed); border-radius: 16px; padding: 20px; margin-bottom: 16px; display: flex; gap: 14px; align-items: flex-start; }
.banner-icon { width: 38px; height: 38px; background: rgba(255,255,255,0.15); border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 18px; }
.banner-label { font-size: 11px; color: rgba(255,255,255,0.6); margin-bottom: 3px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }
.banner-title { font-size: 16px; font-weight: 700; color: #fff; margin-bottom: 5px; }
.banner-reason { font-size: 13px; color: rgba(255,255,255,0.85); line-height: 1.55; margin-bottom: 12px; }
.diff-pills { display: flex; flex-wrap: wrap; gap: 6px; }
.diff-pill { font-size: 11px; color: rgba(255,255,255,0.9); background: rgba(255,255,255,0.15); padding: 4px 10px; border-radius: 99px; }

.cols { display: grid; grid-template-columns: minmax(0,1fr) 200px minmax(0,1fr); gap: 12px; align-items: start; }
@media (max-width: 700px) { .cols { grid-template-columns: 1fr; } .score-card { order: -1; } }

.city-card { background: #fff; border: 1px solid #e5e7eb; border-radius: 16px; overflow: hidden; }
.city-card.winner-a { border: 2px solid #6366f1; box-shadow: 0 0 0 4px rgba(99,102,241,0.08); }
.city-card.winner-b { border: 2px solid #7c3aed; box-shadow: 0 0 0 4px rgba(124,58,237,0.08); }
.card-head { padding: 16px; }
.card-head.a { background: linear-gradient(135deg, #4f46e5, #6366f1); }
.card-head.b { background: linear-gradient(135deg, #7c3aed, #8b5cf6); }
.card-flag { font-size: 28px; margin-bottom: 6px; }
.card-name { font-size: 15px; font-weight: 700; color: #fff; }
.card-tagline { font-size: 11px; color: rgba(255,255,255,0.72); margin-top: 4px; line-height: 1.45; }
.winner-badge { display: inline-flex; align-items: center; gap: 4px; background: #fbbf24; color: #78350f; font-size: 10px; font-weight: 700; padding: 4px 9px; border-radius: 99px; float: right; }

.stats-grid { display: grid; grid-template-columns: 1fr 1fr; border-bottom: 1px solid #f3f4f6; }
.stat-cell { padding: 10px 12px; border-right: 1px solid #f3f4f6; border-bottom: 1px solid #f3f4f6; }
.stat-cell:nth-child(2n) { border-right: none; }
.stat-cell:nth-last-child(-n+2) { border-bottom: none; }
.stat-label { font-size: 10px; color: #9ca3af; margin-bottom: 3px; }
.stat-val { font-size: 12px; font-weight: 600; color: #111; }

.visa-row { padding: 11px 13px; border-bottom: 1px solid #f3f4f6; }
.visa-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 5px; }
.section-label { font-size: 10px; font-weight: 700; color: #9ca3af; letter-spacing: 0.07em; text-transform: uppercase; }
.difficulty { font-size: 10px; font-weight: 700; padding: 3px 8px; border-radius: 99px; }
.diff-easy { background: #d1fae5; color: #065f46; }
.diff-mod { background: #fef3c7; color: #92400e; }
.diff-hard { background: #fee2e2; color: #991b1b; }
.visa-note { font-size: 11px; color: #6b7280; line-height: 1.5; margin-bottom: 6px; }
.visa-routes { display: flex; flex-wrap: wrap; gap: 4px; }
.visa-route { font-size: 10px; background: #f3f4f6; color: #6b7280; padding: 3px 7px; border-radius: 99px; }

.pros-cons { padding: 11px 13px; border-bottom: 1px solid #f3f4f6; }
.pc-item { display: flex; align-items: flex-start; gap: 6px; margin-bottom: 5px; font-size: 11px; color: #4b5563; line-height: 1.45; }
.pc-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; margin-top: 3px; }
.pc-dot.pro { background: #34d399; }
.pc-dot.con { background: #f87171; }

.best-for { padding: 10px 13px; background: #fafafa; border-bottom: 1px solid #f3f4f6; }
.tag-row { display: flex; flex-wrap: wrap; gap: 5px; margin-top: 6px; }
.tag { font-size: 10px; font-weight: 600; padding: 4px 9px; border-radius: 99px; }
.tag-a { background: #eef2ff; color: #3730a3; }
.tag-b { background: #f5f3ff; color: #5b21b6; }

.verdict { padding: 11px 13px; }
.verdict-text { font-size: 11px; color: #6b7280; line-height: 1.6; }

.score-card { background: #fff; border: 1px solid #e5e7eb; border-radius: 16px; padding: 16px; }
.legend { display: flex; justify-content: space-between; margin-bottom: 12px; }
.legend-item { display: flex; align-items: center; gap: 5px; font-size: 11px; font-weight: 600; }
.legend-dot { width: 8px; height: 8px; border-radius: 50%; }
.ld-a { background: #6366f1; }
.ld-b { background: #7c3aed; }
.leg-a { color: #4338ca; }
